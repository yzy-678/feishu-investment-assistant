# ═══════════════════════════════════════════════════════════
# 飞书AI投资助手 — 环境变量配置
# ═══════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── DeepSeek ──────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── 飞书应用 ─────────────────────────────────────────────
# 在 https://open.feishu.cn/app 创建应用后获取
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_BOT_NAME=投资助手
# 事件订阅 > 配置请求网址 时设置的 Verify Token
FEISHU_EVENT_VERIFY_TOKEN=
# 事件订阅 > 加密密钥（可选）
FEISHU_EVENT_ENCRYPT_KEY=

# ── 管理员 ────────────────────────────────────────────────
# 在飞书「设置」>「账号信息」中查看
ADMIN_USER_OPEN_ID=ou_your_open_id

# ── API 安全 ──────────────────────────────────────────────
# 用于 GitHub Actions 调用 Railway API 的鉴权
API_BEARER_TOKEN=your-api-token

# ── 应用运行时 ────────────────────────────────────────────
LOG_LEVEL=INFO
DATABASE_PATH=config/investment.db
DATA_SOURCE=mock
